{
  "name": "smartnotes",
  "displayName": "SmartNotes",
  "description": "Persistent Markdown notes anchored to code lines, with hover tooltips and position tracking.",
  "version": "0.5.0",
  "publisher": "ghazariann",
  "repository": {
    "type": "git",
    "url": "https://github.com/ghazariann/smartnotes"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "media/icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "smartnotes.addNote",
        "title": "SmartNotes: Add Note",
        "icon": "$(add)"
      },
      {
        "command": "smartnotes.editNote",
        "title": "SmartNotes: Edit Note",
        "enablement": "false"
      },
      {
        "command": "smartnotes.deleteNote",
        "title": "SmartNotes: Delete Note",
        "enablement": "false"
      },
      {
        "command": "smartnotes.notes.open",
        "title": "Open Note",
        "icon": "$(go-to-file)"
      },
      {
        "command": "smartnotes.notes.delete",
        "title": "Delete Note",
        "icon": "$(trash)"
      },
      {
        "command": "smartnotes.notes.refresh",
        "title": "Refresh Notes",
        "icon": "$(refresh)"
      },
      {
        "command": "smartnotes.openNote",
        "title": "SmartNotes: Open Note",
        "icon": "$(open-preview)"
      },
      {
        "command": "smartnotes.removeNoteAtLine",
        "title": "SmartNotes: Remove Note"
      },
      {
        "command": "smartnotes.gutterAction",
        "title": "SmartNotes: Note..."
      },
      {
        "command": "smartnotes.copyNote",
        "title": "SmartNotes: Copy Note"
      },
      {
        "command": "smartnotes.pasteNote",
        "title": "SmartNotes: Paste Note"
      },
      {
        "command": "smartnotes.notes.reveal",
        "title": "Go to Line",
        "icon": "$(target)"
      },
      {
        "command": "smartnotes.notes.rename",
        "title": "Rename Note",
        "icon": "$(edit)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "smartnotes",
          "title": "SmartNotes",
          "icon": "media/icon-activity.svg"
        }
      ]
    },
    "views": {
      "smartnotes": [
        {
          "id": "smartnotes.notesView",
          "name": "Notes"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "smartnotes.addNote",
          "group": "smartnotes@1",
          "when": "editorTextFocus"
        }
      ],
      "view/title": [
        {
          "command": "smartnotes.addNote",
          "when": "view == smartnotes.notesView",
          "group": "navigation@1"
        },
        {
          "command": "smartnotes.notes.refresh",
          "when": "view == smartnotes.notesView",
          "group": "navigation@2"
        }
      ],
      "view/title/context": [
        {
          "command": "smartnotes.addNote",
          "when": "view == smartnotes.notesView",
          "group": "smartnotes@1"
        },
        {
          "command": "smartnotes.notes.open",
          "when": "view == smartnotes.notesView",
          "group": "smartnotes@2"
        },
        {
          "command": "smartnotes.notes.delete",
          "when": "view == smartnotes.notesView",
          "group": "smartnotes@3"
        }
      ],
      "editor/lineNumber/context": [
        {
          "command": "smartnotes.addNote",
          "group": "smartnotes@1",
          "when": "editorLineNumber not in smartnotes.linesWithNotes"
        },
        {
          "command": "smartnotes.openNote",
          "group": "smartnotes@2",
          "when": "editorLineNumber in smartnotes.linesWithNotes"
        },
        {
          "command": "smartnotes.removeNoteAtLine",
          "group": "smartnotes@3",
          "when": "editorLineNumber in smartnotes.linesWithNotes"
        },
        {
          "command": "smartnotes.copyNote",
          "group": "smartnotes@4",
          "when": "editorLineNumber in smartnotes.linesWithNotes"
        },
        {
          "command": "smartnotes.pasteNote",
          "group": "smartnotes@5",
          "when": "smartnotes.hasCopiedNote && editorLineNumber not in smartnotes.linesWithNotes"
        }
      ],
      "view/item/context": [
        {
          "command": "smartnotes.notes.rename",
          "when": "view == smartnotes.notesView && viewItem == smartnotesNote",
          "group": "inline@0"
        },
        {
          "command": "smartnotes.notes.reveal",
          "when": "view == smartnotes.notesView && viewItem == smartnotesNote",
          "group": "inline@1"
        },
        {
          "command": "smartnotes.notes.open",
          "when": "view == smartnotes.notesView && viewItem == smartnotesNote",
          "group": "inline@2"
        },
        {
          "command": "smartnotes.notes.delete",
          "when": "view == smartnotes.notesView && viewItem == smartnotesNote",
          "group": "inline@3"
        },
        {
          "command": "smartnotes.notes.open",
          "when": "view == smartnotes.notesView && viewItem == smartnotesNote",
          "group": "context@1"
        },
        {
          "command": "smartnotes.notes.delete",
          "when": "view == smartnotes.notesView && viewItem == smartnotesNote",
          "group": "context@2"
        },
        {
          "command": "smartnotes.addNote",
          "when": "view == smartnotes.notesView && viewItem == smartnotesNote",
          "group": "context@3"
        },
        {
          "command": "smartnotes.addNote",
          "when": "view == smartnotes.notesView && viewItem == smartnotesFile",
          "group": "context@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "smartnotes.addNote",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "SmartNotes",
      "properties": {
        "smartnotes.openBeside": {
          "type": "boolean",
          "default": false,
          "description": "Open notes beside the current editor in a split view instead of in the same tab."
        },
        "smartnotes.anchorTextLength": {
          "type": "number",
          "default": 60,
          "description": "Maximum characters from the source line used in note filenames."
        },
        "smartnotes.showOverviewRuler": {
          "type": "boolean",
          "default": false,
          "description": "Show orange ruler marks in the scrollbar for lines with notes."
        },
        "smartnotes.storagePath": {
          "type": "string",
          "default": "",
          "description": "Custom storage directory for notes. Relative paths are resolved from the workspace root. Defaults to .vscode/.smartnotes/."
        },
        "smartnotes.orphanCleanup": {
          "type": "boolean",
          "default": true,
          "description": "On startup, delete notes whose source file no longer exists in the workspace."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0"
  }
}
